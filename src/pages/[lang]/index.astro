---
import "../../app/global.css";
import ProfileHeader from "../../components/ProfileHeader.astro";
import StatsGrid from "../../components/StatsGrid.astro";
import Section from "../../components/Section.astro";
import AchievementItem from "../../components/AchievementItem.astro";
import ExperienceCard from "../../components/ExperienceCard.astro";
import Tag from "../../components/Tag.astro";
import LanguageRow from "../../components/LanguageRow.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import DownloadButton from "../../components/DownloadButton.astro";
import { getContent, langs, type Lang } from "../../i18n";

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const content = getContent(lang);

const pdfUrl = base + content.meta.pdfUrl;
---

<html lang={lang}>
  <head>
    <title>{content.meta.title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={content.meta.description} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-15JNNZ2EBS"
    ></script>
    <script>
      (window as any).dataLayer = (window as any).dataLayer || [];

      function gtag(...args: any[]) {
        (window as any).dataLayer.push(arguments);
      }

      gtag("js", new Date());

      gtag("config", "G-15JNNZ2EBS");
    </script>
  </head>
  <body>
    <div
      class="max-w-[780px] mx-auto pt-10 px-6 pb-16 max-[768px]:px-5 max-[640px]:pt-6 max-[640px]:pb-12 max-[480px]:px-4 max-[380px]:px-[14px]"
    >
      <div class="flex items-center justify-end mb-4 gap-2.5">
        <LanguageSwitcher currentLang={lang} />
      </div>

      <ProfileHeader profile={content.profile}>
        <DownloadButton href={pdfUrl}
          >{content.common.downloadPdf}</DownloadButton
        >
      </ProfileHeader>

      <StatsGrid stats={content.stats} />

      <Section title={content.sections.about.title}>
        <div
          class="bg-accent-bg border border-accent-bd rounded-md p-[18px_20px] leading-[1.75] text-ink-mid [&_strong]:text-ink [&_strong]:font-semibold max-[640px]:p-4 max-[640px]:leading-[1.65] max-[480px]:text-[14px]"
          set:html={content.sections.about.textHtml}
        />
      </Section>

      <Section title={content.sections.experience.title}>
        <ExperienceCard
          company="Moni Labs"
          companyLink="https://getmoni.io/"
          period={content.experience.moniLabs.period}
          role={content.experience.moniLabs.role}
          dur={content.experience.moniLabs.duration}
        >
          <span slot="description"
            >{content.experience.moniLabs.description}</span
          >

          {
            content.experience.moniLabs.achievements.map((a) => (
              <AchievementItem slot="achievements">
                <Fragment set:html={a} />
              </AchievementItem>
            ))
          }

          {
            content.experience.moniLabs.tags.map((t) => (
              <Tag slot="tags" text={t.text} highlight={t.highlight} />
            ))
          }
        </ExperienceCard>

        <ExperienceCard
          company="getads"
          companyLink="https://getads.ru/"
          period={content.experience.getads.period}
          role={content.experience.getads.role}
          dur={content.experience.getads.duration}
        >
          <span slot="description">{content.experience.getads.description}</span
          >

          {
            content.experience.getads.achievements.map((a) => (
              <AchievementItem slot="achievements">
                <Fragment set:html={a} />
              </AchievementItem>
            ))
          }

          {
            content.experience.getads.tags.map((t) => (
              <Tag slot="tags" text={t.text} highlight={t.highlight} />
            ))
          }
        </ExperienceCard>

        <ExperienceCard
          company="DataArmor"
          companyLink="https://www.dataarmor.ru/"
          period={content.experience.dataArmor.period}
          role={content.experience.dataArmor.role}
          dur={content.experience.dataArmor.duration}
        >
          <span slot="description"
            >{content.experience.dataArmor.description}</span
          >

          {
            content.experience.dataArmor.achievements.map((a) => (
              <AchievementItem slot="achievements">
                <Fragment set:html={a} />
              </AchievementItem>
            ))
          }

          {
            content.experience.dataArmor.tags.map((t) => (
              <Tag slot="tags" text={t.text} highlight={t.highlight} />
            ))
          }
        </ExperienceCard>
      </Section>

      <Section title={content.sections.skills.title}>
        <div
          class="bg-surface border border-line rounded-md p-[16px_18px] flex flex-wrap gap-[7px] max-[640px]:p-4 max-[640px]:gap-[6px]"
        >
          {
            content.skillsTags.map((t) => (
              <Tag text={t.text} highlight={t.highlight} />
            ))
          }
        </div>
      </Section>

      <Section title={content.sections.languages.title}>
        <div class="flex flex-col gap-[8px]">
          {
            content.languages.map((l) => (
              <LanguageRow name={l.name} level={l.level} />
            ))
          }
        </div>
      </Section>
    </div>
  </body>
</html>
