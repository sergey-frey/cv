---
import { cn } from "../shared/utils/cn";

interface Props {
  company: string;
  companyLink: string;
  period: string;
  role: string;
  dur: string;
}

const { company, companyLink, period, role, dur } = Astro.props;
---

<div
  class={cn(
    "bg-white border border-line rounded-md mb-2.5 px-5 pt-5 pb-4",
    "max-[640px]:px-4 max-[640px]:pt-4 max-[640px]:pb-3",
  )}
>
  <div class="flex items-center gap-2.5 mb-1 flex-wrap max-[640px]:gap-1.5">
    <span class="text-[16px] font-bold text-ink">{company}</span>
    <a
      href={companyLink}
      target="_blank"
      rel="noopener noreferrer"
      class="text-[14px] text-blue underline break-all max-[640px]:text-[13px]"
    >
      {companyLink}
    </a>
    <span
      class={cn(
        "text-[10.5px] rounded-[6px] px-2 py-1 whitespace-nowrap shrink-0",
        "text-ink-faint bg-surface border border-line",
        "ml-auto",
        "max-[640px]:ml-0 max-[640px]:self-start",
      )}
    >
      {period}
    </span>
  </div>

  <div
    class="flex items-center gap-[8px] mb-[12px] flex-wrap max-[640px]:mb-[10px]"
  >
    <span class="text-[13px] text-ink-soft italic max-[640px]:text-[12px]">
      {role}
    </span>
    <span
      class="text-[11px] font-semibold text-accent bg-accent-bg border border-accent-bd rounded-full px-[9px] py-[2px]"
    >
      {dur}
    </span>
  </div>

  <p
    class="text-[13px] text-ink-soft italic leading-[1.55] mb-[12px] max-[640px]:text-[12px]"
  >
    <slot name="description" />
  </p>

  <div class="mb-[12px] max-[640px]:mb-[10px]">
    <slot name="achievements" />
  </div>

  <div class="flex flex-wrap gap-[6px] mt-[2px] max-[640px]:gap-[5px]">
    <slot name="tags" />
  </div>
</div>
