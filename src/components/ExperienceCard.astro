---
import { cn } from "../shared/utils/cn";

interface Props {
  company: string;
  companyLink: string;
  period: string;
  role: string;
  dur: string;
}

const { company, companyLink, period, role, dur } = Astro.props;
---

<div
  class="bg-white border border-line rounded-md mb-[10px] transition-shadow duration-150 hover:shadow-[0_4px_18px_rgba(0,0,0,0.07)] px-[20px] pt-[20px] pb-[16px] max-[480px]:px-[14px] max-[480px]:pt-[16px] max-[480px]:pb-[12px]"
>
  <div
    class="flex items-center gap-[10px] mb-[4px] flex-wrap max-[480px]:flex-col max-[480px]:gap-[4px]"
  >
    <span class="text-[16px] font-bold text-ink">{company}</span>
    <a
      href={companyLink}
      target="_blank"
      rel="noopener noreferrer"
      class="text-[14px] text-blue underline"
    >
      {companyLink}
    </a>
    <span
      class={cn(
        "text-[10.5px] rounded-[6px] px-2 py-[3px] whitespace-nowrap shrink-0",
        "text-ink-faint bg-surface border border-line",
        "ml-auto",
        "max-[480px]:self-start",
      )}
    >
      {period}
    </span>
  </div>

  <div class="flex items-center gap-[8px] mb-[12px] flex-wrap">
    <span class="text-[13px] text-ink-soft italic">{role}</span>
    <span
      class="text-[11px] font-semibold text-accent bg-accent-bg border border-accent-bd rounded-full px-[9px] py-[2px]"
    >
      {dur}
    </span>
  </div>

  <p class="text-[13px] text-ink-soft italic leading-[1.55] mb-[12px]">
    <slot name="description" />
  </p>

  <div class="mb-[12px]">
    <slot name="achievements" />
  </div>

  <div class="flex flex-wrap gap-[6px] mt-[2px]">
    <slot name="tags" />
  </div>
</div>
