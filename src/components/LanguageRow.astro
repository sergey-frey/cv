---
import { cn } from "../shared/utils/cn";

interface Props {
  name: string;
  level: string;
}

const { name, level } = Astro.props;
---

<div
  class={cn(
    "flex items-center justify-between gap-3 bg-white border border-line rounded-sm py-3 px-4",
    "max-[480px]:flex-col max-[480px]:items-start max-[480px]:px-3 max-[480px]:py-[10px]",
  )}
>
  <span class="font-semibold text-[14px] max-[480px]:text-[13px]">{name}</span>

  <span
    class="text-[11px] text-ink-soft bg-surface border border-line rounded-sm px-[9px] py-[3px]"
  >
    {level}
  </span>
</div>
