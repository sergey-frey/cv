---
import type { Content } from "../i18n";

interface Props {
  profile: Content["profile"];
}

const {
  avatarText,
  name,
  badgeText,
  roleStrong,
  roleTail,
  contacts: { email, telegram, location, emailAriaLabel, telegramAriaLabel },
} = Astro.props.profile;
---

<header class="mb-[28px] max-[640px]:mb-6">
  <div
    class="w-[62px] h-[62px] rounded-full flex items-center justify-center shrink-0 text-[20px] font-bold text-[#8b3010] bg-linear-to-br from-accent-bd to-[#f5a07a] mb-[18px] max-[640px]:w-14 max-[640px]:h-14 max-[640px]:text-[18px] max-[640px]:mb-4"
  >
    {avatarText}
  </div>

  <div class="flex items-end gap-[14px] flex-wrap mb-[8px] max-[640px]:gap-[10px]">
    <h1
      class="text-[clamp(26px,7vw,40px)] font-bold text-ink leading-[1.1] tracking-[-0.5px] max-[640px]:basis-full"
    >
      {name}
    </h1>

    <span
      class="inline-flex items-center gap-[6px] bg-green-bg text-green text-[12px] font-semibold px-[12px] py-[5px] rounded-full whitespace-nowrap relative before:content-[''] before:w-[7px] before:h-[7px] before:bg-green before:rounded-full before:animate-[blink_2s_infinite] before:inline-block before:shrink-0 max-[640px]:text-[11px] max-[640px]:px-[10px] max-[640px]:py-[4px]"
    >
      {badgeText}
    </span>
  </div>

  <p
    class="text-[14.5px] text-ink-soft mb-[20px] [&_strong]:text-ink-mid [&_strong]:font-semibold max-[640px]:text-[14px] max-[640px]:leading-[1.55] max-[640px]:mb-4"
  >
    <strong>{roleStrong}</strong> · {roleTail}
  </p>

  <div class="flex flex-wrap gap-[8px] max-[640px]:flex-col max-[640px]:items-stretch">
    <a
      class="inline-flex items-center gap-[6px] bg-surface border border-line rounded-full px-[14px] py-[7px] text-[13px] font-medium text-ink-mid no-underline transition-colors duration-[0.12s] hover:bg-surface2 hover:border-ink-faint min-w-0 max-[640px]:w-full max-[640px]:justify-center max-[640px]:text-[12px] max-[640px]:py-[10px] max-[640px]:px-3"
      href={`mailto:${email}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={emailAriaLabel}
    >
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="w-[14px] h-[14px] opacity-60 shrink-0"
      >
        <rect x="1" y="3" width="14" height="10" rx="2"></rect>
        <path d="M1 5l7 5 7-5"></path>
      </svg>
      <span class="min-w-0 break-all text-center">{email}</span>
    </a>

    <a
      class="inline-flex items-center gap-[6px] bg-surface border border-line rounded-full px-[14px] py-[7px] text-[13px] font-medium text-ink-mid no-underline transition-colors duration-[0.12s] hover:bg-surface2 hover:border-ink-faint min-w-0 max-[640px]:w-full max-[640px]:justify-center max-[640px]:text-[12px] max-[640px]:py-[10px] max-[640px]:px-3"
      href="https://t.me/sergeyfrey"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={telegramAriaLabel}
    >
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="w-[14px] h-[14px] opacity-60 shrink-0"
      >
        <path d="M1.5 8L6 10.5l1.5 4 2.5-3 3.5 2.5L15.5 1 1.5 8z"></path>
        <path d="M6 10.5l1-3.5 5-4"></path>
      </svg>
      <span class="min-w-0 break-all text-center">{telegram}</span>
    </a>

    <span
      class="inline-flex items-center gap-[6px] bg-surface border border-line rounded-full px-[14px] py-[7px] text-[13px] font-medium text-ink-mid no-underline transition-colors duration-[0.12s] hover:bg-surface2 hover:border-ink-faint min-w-0 max-[640px]:w-full max-[640px]:justify-center max-[640px]:text-[12px] max-[640px]:py-[10px] max-[640px]:px-3"
    >
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="w-[14px] h-[14px] opacity-60 shrink-0"
      >
        <circle cx="8" cy="6.5" r="2.5"></circle>
        <path d="M8 1a6 6 0 016 6c0 4-6 9-6 9S2 11 2 7a6 6 0 016-6z"></path>
      </svg>
      <span class="min-w-0 wrap-break-word text-center">{location}</span>
    </span>
  </div>
</header>
